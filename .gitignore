# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Archive folder (non-production files)
.archive/

# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Packaging / build
build/
dist/
*.egg-info/
.eggs/

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.cache/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/
notebooks/*.ipynb

# IDE settings
.vscode/
.idea/

# Environment variables
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env.local
frontend/.env
frontend/.env.*

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.pid

# Installers and archives (local downloads/exports)
*.msi
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# Frontend – Next.js
node_modules/
.next/
out/
.vercel/
frontend/node_modules/
frontend/.next/
frontend/out/

# Local runtime outputs
reports/
*.sqlite3
tmp/
temp/

# Model artifacts (do not commit model binaries)
models/*.pkl
models/*.h5
models/*.npy
models/*.pt
models/*.pth
models/*.onnx
models/*.json

# Keep only README in models folder
!models/README.md

# Large/local processed data artifacts (do not commit binary data)
data/*.npy
data/*.csv
data/*.json
data/*.txt
data/videos/

# Keep only README in data folder
!data/README.md
frontend-react/
frontend-v2/
# Keep local-only cleanup targets out of Git (no deletion required)
reports/exports/

# Legacy files (archived or removed)
model_training_legacy_backup.py
model_training.ipynb

# Benchmark outputs
benchmark_results.json
