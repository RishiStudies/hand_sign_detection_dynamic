# Backend runtime settings
FRONTEND_URL=http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO

# Inference input limits
MAX_UPLOAD_BYTES=2097152
MAX_SEQUENCE_FRAMES=30
MAX_CSV_UPLOAD_BYTES=10485760

# Shared training/inference feature contract
# Use the same value for both training and runtime.
# Supported values: histogram, mediapipe
FEATURE_SCHEMA=histogram

# Overload protection
RATE_LIMIT_WINDOW_SECONDS=60
MAX_PREDICT_REQUESTS_PER_WINDOW=180
MAX_SEQUENCE_REQUESTS_PER_WINDOW=30
MAX_TRAIN_REQUESTS_PER_WINDOW=6
MAX_CONCURRENT_SEQUENCE_REQUESTS=2

# Optional distributed throttling backend
REDIS_URL=redis://localhost:6379/0
REDIS_RATE_LIMIT_PREFIX=hsd:ratelimit
REDIS_COMBO_PREFIX=hsd:combo
COMBO_STATE_TTL_SECONDS=300
JOB_QUEUE_NAME=training
JOB_TIMEOUT_SECONDS=7200

# Security for mutation/training endpoints.
# Leave empty for local experimentation only.
TRAINING_API_KEY=
