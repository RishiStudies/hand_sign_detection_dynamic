# API Server Configuration

# Frontend URL for redirects and CORS
FRONTEND_URL=http://127.0.0.1:3000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ========== SECURITY ==========
# CRITICAL: Set a strong API key in production for training endpoints
# Format: Random string, minimum 32 characters recommended
# Leave empty ONLY for local development (training endpoints will be accessible)
TRAINING_API_KEY=change-me-in-production-with-strong-key

# ========== INFERENCE INPUT LIMITS ==========
# Maximum file size for single frame uploads (default 2MB)
MAX_UPLOAD_BYTES=2097152

# Maximum file size for CSV training uploads (default 10MB)
MAX_CSV_UPLOAD_BYTES=10485760

# Number of frames per sequence for LSTM inference
MAX_SEQUENCE_FRAMES=30

# ========== FEATURE CONFIGURATION ==========
# Feature schema consistency check (must match training)
# Supported: histogram (8-dim), mediapipe (63-dim)
FEATURE_SCHEMA=histogram

# ========== RATE LIMITING ==========
# Rate limit window in seconds
RATE_LIMIT_WINDOW_SECONDS=60

# Max requests per window for /predict endpoint
MAX_PREDICT_REQUESTS_PER_WINDOW=180

# Max requests per window for /predict_sequence endpoint
MAX_SEQUENCE_REQUESTS_PER_WINDOW=30

# Max requests per window for all /train/* endpoints
MAX_TRAIN_REQUESTS_PER_WINDOW=6

# Max concurrent LSTM sequence inference requests
MAX_CONCURRENT_SEQUENCE_REQUESTS=2

# ========== DISTRIBUTED BACKENDS ==========
# Redis connection URL for distributed rate limiting and session state
# Leave empty to use in-memory fallback (suitable for single-server deployments)
REDIS_URL=redis://localhost:6379/0

# Redis key prefixes
REDIS_RATE_LIMIT_PREFIX=hsd:ratelimit
REDIS_COMBO_PREFIX=hsd:combo

# ========== SESSION & JOBS ==========
# Combo detection session TTL in seconds
COMBO_STATE_TTL_SECONDS=300

# Background job queue name
JOB_QUEUE_NAME=training

# Maximum job execution time (seconds, 2 hours default)
JOB_TIMEOUT_SECONDS=7200

